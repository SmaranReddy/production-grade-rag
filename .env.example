# ─────────────────────────────────────────────────────────────
# Enterprise Knowledge Platform — environment variables
# Copy this file to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# Groq API key — get one at https://console.groq.com
GROQ_API_KEY=gsk_...

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────

# SQLite (default, fine for development)
DATABASE_URL=sqlite+aiosqlite:///./enterprise_kb.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/enterprise_kb

# ── Storage paths ─────────────────────────────────────────────

# Directory for uploaded raw files
UPLOAD_DIR=backend/data/uploads

# Directory for per-KB FAISS + BM25 indexes
INDEX_DIR=backend/data/indexes

# ── Embedding model ───────────────────────────────────────────

# Must match the model used to build any existing indexes
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── LLM ───────────────────────────────────────────────────────

LLM_MODEL=llama-3.1-8b-instant

# ── Auth token expiry ─────────────────────────────────────────

ACCESS_TOKEN_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Ingestion ─────────────────────────────────────────────────

CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=64
MAX_UPLOAD_MB=50

# ── Rate limiting ─────────────────────────────────────────────

DEFAULT_RATE_LIMIT_RPM=60

# ── Cache ─────────────────────────────────────────────────────

CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=500
